        <!-- Message 27: read_data() 리턴 (dashed return) -->
        <mxCell id="m27" value="27. read_data() 리턴" style="endArrow=open;endFill=0;dashed=1;dashPattern=6 4;strokeColor=#666666;fontColor=#666666;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
