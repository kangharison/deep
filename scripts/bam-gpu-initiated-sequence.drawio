        <!-- Message 29: 캐시 페이지 주소 반환 (dashed return) -->
        <mxCell id="m29" value="29. 캐시 페이지 주소 반환" style="endArrow=open;endFill=0;dashed=1;dashPattern=6 4;strokeColor=#666666;fontColor=#666666;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
