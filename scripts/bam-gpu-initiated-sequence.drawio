              <mxPoint x="810" y="3740"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Message 25: CQ Doorbell write (sync arrow) -->
        <mxCell id="m25" value="25. CQ Doorbell write&#xa;    st.mmio PTX" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="728" y="3830" as="sourcePoint"/>
            <mxPoint x="1012" y="3830" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Message 26: put_cid() -->
        <mxCell id="m26" value="26. put_cid()&#xa;    Command ID 반환" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
