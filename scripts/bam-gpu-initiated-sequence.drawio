            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Message 22: CQ entry write -->
        <mxCell id="m22" value="22. CQ entry write&#xa;    to GPU memory (BAR)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
            <mxPoint x="1028" y="3070" as="sourcePoint"/>
            <mxPoint x="1028" y="3150" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1100" y="3070"/>
              <mxPoint x="1100" y="3150"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 7: GPU Polling Completion                                  -->
        <!-- ================================================================ -->

        <!-- Message 23: cq_poll() -->
        <mxCell id="m23" value="23. cq_poll()&#xa;    phase bit + CID 매칭&#xa;    (busy wait / GPU spin)" style="endArrow=block;endFill=1;strokeColor=#CC6600;fontColor=#CC6600;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
