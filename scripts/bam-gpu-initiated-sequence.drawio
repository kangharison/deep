        </mxCell>

        <!-- Message 24: cq_dequeue() -->
        <mxCell id="m24" value="24. cq_dequeue()&#xa;    leader가 CQ head 업데이트" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
