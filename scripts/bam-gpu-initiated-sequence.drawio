            <mxPoint x="428" y="4300" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Message 28: state = VALID -->
        <mxCell id="m28" value="28. state = VALID&#xa;    BUSY→VALID 전환&#xa;    xor 0xc0000000" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
