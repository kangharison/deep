        <!-- Step 20: Parallel Queue → NVMe SSD: SQ Doorbell (async dashed) -->
        <mxCell id="m20" value="20. st.mmio SQ Doorbell write&#xa;    (PTX MMIO instruction)" style="endArrow=open;endFill=0;dashed=1;strokeColor=#CC0000;fontColor=#CC0000;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="758" y="2420" as="sourcePoint"/>
            <mxPoint x="1042" y="2420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 4: SSD Processing (Steps 21-24)                           -->
        <!-- ================================================================ -->

        <!-- Step 21: NVMe SSD self-call: SQ fetch -->
        <mxCell id="m21" value="21. SQ fetch&#xa;    (DMA read cmd 64B)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
