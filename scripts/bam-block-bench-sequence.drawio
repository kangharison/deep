              <mxPoint x="1140" y="2840"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 23: NVMe SSD self-call: PCIe P2P DMA write → GPU memory -->
        <mxCell id="m23" value="23. PCIe P2P DMA write → GPU memory&#xa;    (PRP1 주소, CPU DRAM bypass)" style="endArrow=block;endFill=1;strokeColor=#CC0000;fontColor=#CC0000;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
