        <!-- Step 16: Parallel Queue self-call: memcpy command -->
        <mxCell id="m16" value="16. memcpy(SQ[pos], &amp;cmd, 64B)&#xa;    NVMe command 복사" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
