              <mxPoint x="870" y="4260"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 31: Parallel Queue self-call: leader election head -->
        <mxCell id="m31" value="31. leader election&#xa;    head_lock.fetch_or(LOCKED)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
