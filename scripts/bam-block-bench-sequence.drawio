              <mxPoint x="880" y="4530"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 33: Parallel Queue → NVMe SSD: CQ Doorbell write (sync arrow) -->
        <mxCell id="m33" value="33. st.mmio CQ Doorbell write" style="endArrow=block;endFill=1;strokeColor=#CC0000;fontColor=#CC0000;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
