            <mxPoint x="1058" y="2990" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1160" y="2890"/>
              <mxPoint x="1160" y="2990"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 24: NVMe SSD self-call: CQ entry write → GPU memory -->
        <mxCell id="m24" value="24. CQ entry write → GPU memory&#xa;    (DMA)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
            <mxPoint x="1058" y="3040" as="sourcePoint"/>
            <mxPoint x="1058" y="3130" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1150" y="3040"/>
              <mxPoint x="1150" y="3130"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 5: GPU Polling Completion (Steps 25-33)                   -->
        <!-- ================================================================ -->

        <!-- Step 25: BaM I/O Layer → Parallel Queue: cq_poll -->
        <mxCell id="m25" value="25. cq_poll(&amp;qp-&gt;cq, cid)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
