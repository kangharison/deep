        <!-- Step 19: Parallel Queue self-call: move_tail -->
        <mxCell id="m19" value="19. move_tail()&#xa;    연속 LOCKED 슬롯 수집" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
