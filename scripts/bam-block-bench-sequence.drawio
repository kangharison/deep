        <mxCell id="m37" value="37. read_data() 리턴" style="endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
