        <!-- Step 18: Parallel Queue self-call: leader election -->
        <mxCell id="m18" value="18. leader election&#xa;    tail_lock.fetch_or(LOCKED)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
