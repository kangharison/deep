        <mxCell id="m14" value="14. ticket = in_ticket.fetch_add(1)&#xa;    순서 티켓 할당" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
