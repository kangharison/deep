            <mxPoint x="742" y="3720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 26: Parallel Queue self-call: CQ scan -->
        <mxCell id="m26" value="26. CQ 스캔&#xa;    phase bit + CID 매칭 (busy wait)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
