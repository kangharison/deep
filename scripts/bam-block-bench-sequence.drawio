        </mxCell>

        <!-- ================================================================ -->
        <!-- PHASE 6: Cleanup & Return (Steps 34-37)                         -->
        <!-- ================================================================ -->

        <!-- Step 34: BaM I/O Layer → Parallel Queue: put_cid -->
        <mxCell id="m34" value="34. put_cid(&amp;qp-&gt;sq, cid)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
