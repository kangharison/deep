            <mxPoint x="1058" y="2710" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1140" y="2630"/>
              <mxPoint x="1140" y="2710"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 22: NVMe SSD self-call: NAND Flash read -->
        <mxCell id="m22" value="22. NAND Flash read" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
