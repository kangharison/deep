            <mxPoint x="458" y="4040" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 29: BaM I/O Layer → Parallel Queue: cq_dequeue -->
        <mxCell id="m29" value="29. cq_dequeue(&amp;qp-&gt;cq, cq_pos, &amp;qp-&gt;sq)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
