              <mxPoint x="880" y="3980"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 28: Parallel Queue → BaM I/O Layer: CQ position return (dashed) -->
        <mxCell id="m28" value="28. CQ position 반환" style="endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
