        <!-- Step 15: Parallel Queue self-call: spin-wait -->
        <mxCell id="m15" value="15. spin-wait: tickets[pos] == expected_id&#xa;    순서 대기 (busy loop)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
