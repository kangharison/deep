            <mxPoint x="742" y="4120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 30: Parallel Queue self-call: head_mark -->
        <mxCell id="m30" value="30. head_mark[pos] = LOCKED&#xa;    처리 완료 표시" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
