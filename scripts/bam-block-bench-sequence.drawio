              <mxPoint x="870" y="3860"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 27: Parallel Queue self-call: nanosleep backoff -->
        <mxCell id="m27" value="27. __nanosleep() exponential backoff&#xa;    (8→256ns)" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
          <mxGeometry x="0.3" relative="1" as="geometry">
