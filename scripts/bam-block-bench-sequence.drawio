              <mxPoint x="870" y="4380"/>
            </Array>
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- Step 32: Parallel Queue self-call: move_head_cq -->
        <mxCell id="m32" value="32. move_head_cq()&#xa;    연속 처리된 엔트리 수집&#xa;    + SQ head 업데이트" style="endArrow=block;endFill=1;strokeColor=#333333;fontColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;curved=1;" edge="1" parent="1">
